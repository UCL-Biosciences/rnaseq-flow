/*
 * conf/base.config
 * ------------------------------------------------------------------
 * Default compute resources for every process, keyed off the process
 * labels (process_single / process_low / process_medium / process_high).
 *
 * Ceilings: process.resourceLimits caps every request at
 * --max_cpus / --max_memory / --max_time (Nextflow's native mechanism,
 * >= 24.04). This replaced the old check_max() helper, which the strict
 * config parser (default from Nextflow 25.10 / 26.x) rejects because it is
 * a function definition inside a config file.
 *
 * Requests are multiplied by task.attempt, so a failed task is retried once
 * with more memory/time; resourceLimits then clamps the retried request too.
 */

process {

    // Cap every per-process request at the configured maxima.
    resourceLimits = [
        cpus  : (params.max_cpus   as int),
        memory: (params.max_memory as nextflow.util.MemoryUnit),
        time  : (params.max_time   as nextflow.util.Duration)
    ]

    cpus   = { 1     * task.attempt }
    memory = { 6.GB  * task.attempt }
    time   = { 4.h   * task.attempt }

    // Retry once on the exit codes typically associated with out-of-memory
    // or scheduler kills; otherwise stop the run.
    errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }
    maxRetries    = 1
    maxErrors     = '-1'

    withLabel:process_single {
        cpus   = { 1 }
        memory = { 4.GB  * task.attempt }
        time   = { 4.h   * task.attempt }
    }
    withLabel:process_low {
        cpus   = { 2     * task.attempt }
        memory = { 8.GB  * task.attempt }
        time   = { 4.h   * task.attempt }
    }
    withLabel:process_medium {
        cpus   = { 6     * task.attempt }
        memory = { 24.GB * task.attempt }
        time   = { 8.h   * task.attempt }
    }
    withLabel:process_high {
        cpus   = { 12    * task.attempt }
        memory = { 48.GB * task.attempt }
        time   = { 16.h  * task.attempt }
    }

    // STAR genome indexing of a mammalian genome is memory-hungry.
    withName:STAR_GENOME_GENERATE {
        memory = { 38.GB * task.attempt }
    }

    // A splice-aware HISAT2 index (hisat2-build --ss --exon) is far hungrier
    // still -- of the order of 200 GB for human, because peak memory is driven by
    // the splice graph built from the GTF rather than by the genome. Rather than
    // a flat figure (which would make a small genome reserve a mammalian-sized
    // node), estimate it from the GTF:
    //
    //     8 GB base (genome FM index)  +  45 GB per GB of *uncompressed* GTF
    //
    // anchored on human (~4.34 GB GTF -> ~204 GB, within the HISAT2 authors'
    // 160-200 GB). A gzipped GTF is scaled up by 33x, the compression ratio
    // measured on Ensembl release-116 human/mouse GTFs (the two where the ceiling
    // bites); smaller genomes compress less, so this over-estimates them, which
    // is the safe direction -- a few spare GB, never an OOM. Override the whole
    // calculation with --hisat2_build_memory '200.GB'.
    //
    // The estimate lives once, in ext.build_memory; the memory request derives
    // from it. resourceLimits then caps the request at --max_memory, and when the
    // cap bites HISAT2_BUILD compares task.memory against ext.build_memory and
    // drops --ss/--exon rather than being OOM-killed (see the module).
    //
    // NOTE: this is an inline closure, not a helper function, because the strict
    // config parser forbids function definitions in a config file.
    withName:HISAT2_BUILD {
        ext.build_memory = {
            if (params.hisat2_build_memory) {
                params.hisat2_build_memory as nextflow.util.MemoryUnit
            } else {
                long bytes = 0
                boolean gz = false
                if (params.gtf) {
                    def gtf_file = new File(params.gtf.toString())
                    if (gtf_file.exists()) {
                        bytes = gtf_file.length()
                        gz    = gtf_file.name.endsWith('.gz')
                    }
                }
                if (bytes <= 0) {
                    // No readable GTF at submission time: assume the mammalian
                    // worst case rather than silently under-requesting.
                    '200.GB' as nextflow.util.MemoryUnit
                } else {
                    double gtf_gb = bytes / 1073741824d
                    if (gz) gtf_gb = gtf_gb * 33
                    long gb = Math.max(8L, Math.ceil(8 + 45 * gtf_gb) as long)
                    "${gb}.GB" as nextflow.util.MemoryUnit
                }
            }
        }
        memory = { (task.ext.build_memory as nextflow.util.MemoryUnit) * task.attempt }
    }
}
